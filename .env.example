# Cynthia Studio OS — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Your unique API key for securing the FastAPI + MCP endpoints
# Generate: openssl rand -hex 32
CYNTHIA_API_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────

# Your domain (e.g. studio.yourdomain.com)
DOMAIN=studio.yourdomain.com

# Email for Let's Encrypt SSL certificate
SSL_EMAIL=admin@yourdomain.com

# Hostinger VPS IP or hostname
VPS_HOST=YOUR_VPS_IP

# ── Optional ──────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (for private repo scanning)
GITHUB_TOKEN=ghp_...

# Claude model to use (default: claude-opus-4-7)
ANTHROPIC_MODEL=claude-opus-4-7

# ── 3D Worlds (HuggingFace Inference API) ─────────────────────────────────────
# Required for tencent/HY-WorldPlay 3D world generation
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ── Video Generation (Seedance by ByteDance) ─────────────────────────────────
# Required for bytedance/seedance-1-0 via Replicate
# Get token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...
