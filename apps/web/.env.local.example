# Cynthia Studio OS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Required for AI Command Center ─────────────────────────────────────────
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: GitHub Repo Scanning ─────────────────────────────────────────
# Classic token with repo:read scope — https://github.com/settings/tokens
# If omitted, public repos are scanned unauthenticated (60 req/hr limit).
GITHUB_TOKEN=ghp_...

# ─── Optional: Override default model ────────────────────────────────────────
# Defaults to claude-opus-4-7 if not set
# ANTHROPIC_MODEL=claude-sonnet-4-6
